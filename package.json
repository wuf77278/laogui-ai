{
  "name": "laogui-ai",
  "version": "2.2.1",
  "description": "面向建筑、室内、民宿和商业空间设计师的本地 AI 创意工作台",
  "private": true,
  "license": "MIT",
  "author": "wuf77278",
  "type": "module",
  "main": "electron/main.cjs",
  "files": [
    "server.mjs",
    "prompt-library.mjs",
    "electron/",
    "engines/",
    "public/",
    "scripts/doctor.mjs",
    "scripts/sync-vendor.mjs",
    "scripts/build-image-studio-engine.mjs",
    "package.json",
    "!public/generated/",
    "!public/archive/",
    "!public/vendor/",
    "!**/.DS_Store"
  ],
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "api": "node scripts/laogui-api.mjs",
    "desktop": "electron .",
    "postinstall": "node scripts/sync-vendor.mjs",
    "vendor:sync": "node scripts/sync-vendor.mjs",
    "check:vendor": "node scripts/sync-vendor.mjs --check",
    "engine:image-studio": "node scripts/build-image-studio-engine.mjs",
    "engine:image-studio:mac": "node scripts/build-image-studio-engine.mjs --target darwin-arm64,darwin-x64",
    "engine:image-studio:win": "node scripts/build-image-studio-engine.mjs --target win32-x64,win32-arm64",
    "engine:image-studio:all": "node scripts/build-image-studio-engine.mjs --all",
    "pack:mac": "electron-builder --mac --arm64 --x64",
    "pack:mac:arm64": "electron-builder --mac --arm64",
    "pack:mac:x64": "electron-builder --mac --x64",
    "pack:win": "electron-builder --win --x64",
    "pack:win:arm64": "electron-builder --win --arm64",
    "publish:win": "npm run check && npm run engine:image-studio:win && electron-builder --win --x64 --publish always",
    "pack:all": "electron-builder --mac --arm64 --x64 --win --x64",
    "check": "node --check server.mjs && node --check public/app.js && node --check electron/main.cjs && node --check electron/preload.cjs && node --check scripts/doctor.mjs && node --check scripts/sync-vendor.mjs && npm run check:vendor",
    "doctor": "node scripts/doctor.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "cn.laogui.ai",
    "productName": "老鬼AI",
    "publish": [
      {
        "provider": "github",
        "owner": "wuf77278",
        "repo": "laogui-ai",
        "releaseType": "release"
      }
    ],
    "asar": true,
    "files": [
      "server.mjs",
      "prompt-library.mjs",
      "electron/**",
      "public/**",
      "!public/generated/**",
      "!public/archive/**",
      "!**/.DS_Store",
      "scripts/doctor.mjs",
      "scripts/sync-vendor.mjs",
      "scripts/build-image-studio-engine.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "engines",
        "to": "engines",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.graphics-design",
      "artifactName": "LaoguiAI-v${version}-mac-${arch}.${ext}",
      "icon": "build/icon.icns"
    },
    "win": {
      "artifactName": "LaoguiAI-v${version}-windows-${arch}-setup.${ext}",
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "老鬼AI",
      "deleteAppDataOnUninstall": false
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "pannellum": "^2.5.7",
    "three": "^0.160.0"
  }
}
