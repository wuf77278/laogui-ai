PORT=4177
# 默认只监听本机；局域网/内网穿透分享时改成 0.0.0.0，并同时配置 LAOGUI_API_TOKEN。
HOST=127.0.0.1
# 桌面版会自动设置到系统用户目录；普通 node 启动时留空会继续使用项目目录。
LAOGUI_DATA_DIR=
REASONING_BASE_URL=
REASONING_API_KEY=
REASONING_MODEL=gpt-5.5
IMAGE_BASE_URL=
IMAGE_BASE_URLS=
IMAGE_COST_FIRST_BASE_URLS=
IMAGE_INCLUDE_DEFAULT_BASE_URLS=0
IMAGE_API_KEY=
# Image Studio profile-style upstream contract used by the bundled engine.
# Matches Image Studio: Responses API + HTTP SSE + OpenAI standard fields.
IMAGE_API_MODE=responses
IMAGE_STUDIO_RESPONSES_TRANSPORT=sse
IMAGE_STUDIO_REQUEST_POLICY=openai
# Images API 默认使用普通 JSON 返回，不发送 stream / partial_images。
# 只有上游明确支持 Images 流式事件时才改为 0。
IMAGE_STUDIO_IMAGES_NEW_API_COMPAT=1
IMAGE_STUDIO_REASONING_EFFORT=xhigh
# Used only when the UI thinking mode is off, so direct image generation stays fast.
IMAGE_STUDIO_FAST_REASONING_EFFORT=low
FAST_IMAGE_PROMPT_MAX_CHARS=1200
IMAGE_GENERATIONS_PATH=/v1/images/generations
IMAGE_EDITS_PATH=/v1/images/edits
# Optional custom HTTP image provider manifest. Keep empty for standard OpenAI-compatible responses.
IMAGE_PROVIDER_MANIFEST=
IMAGE_RESPONSES_PATH=/v1/responses
IMAGE_MODEL=gpt-image-2
IMAGE_GEN_SKILL_MAX_ATTEMPTS=2
IMAGE_COST_FIRST_MAX_ATTEMPTS=2
IMAGE_ENDPOINT_PRECHECK_TTL_SECONDS=300
IMAGE_ALLOW_LEGACY_FALLBACK=0
IMAGE_GENERATION_CONCURRENCY=2
IMAGE_GENERATION_QUEUE_MAX_PENDING=12
IMAGE_GENERATION_QUEUE_TIMEOUT_SECONDS=600
# Image Studio go-cli 是老鬼AI软件版的生图核心中枢。required 表示必须通过
# gptcodex-image 引擎出图；打包给朋友前请用 npm run engine:image-studio 构建
# 当前平台产物，例如 engines/image-studio/darwin-arm64/gptcodex-image。
# IMAGE_STUDIO_CLI_PATH 仅用于本机开发调试，不是朋友版依赖。
IMAGE_STUDIO_ENGINE=required
IMAGE_STUDIO_CLI_PATH=
IMAGE_STUDIO_OUTPUT_DIR=
IMAGE_STUDIO_TIMEOUT_SECONDS=360
IMAGE_STUDIO_PARTIAL_IMAGES=0
IMAGE_STUDIO_AUTO_RETRY_COUNT=1
IMAGE_STUDIO_ALLOW_NATIVE_FALLBACK=0
# 开发后备：接入本机 Codex skill。正式软件分发不依赖它，默认关闭。
IMAGE_STUDIO_FHL_ENABLED=disabled
IMAGE_STUDIO_FHL_SCRIPT=/Users/Apple_501/.codex/skills/image-studio-fhl/scripts/yingfang_image.py
IMAGE_STUDIO_FHL_PROVIDER=auto
IMAGE_STUDIO_FHL_OUTPUT_DIR=
IMAGE_STUDIO_FHL_TIMEOUT_SECONDS=300
MAX_JSON_BODY_MB=80
# 外部访问、局域网分享、内网穿透时必配。仅本机自用 localhost 时可留空。
LAOGUI_API_TOKEN=replace-with-a-private-token
API_CORS_ORIGIN=https://your-tunnel-domain.example
# 仅在受控内网里明确需要无口令访问时设为 1；默认远程请求无 token 会被拒绝。
LAOGUI_ALLOW_UNAUTHENTICATED_REMOTE=0

# Codex / CLI 桥接客户端默认读取这两个值；本机默认值也可以不填。
LAOGUI_API_BASE_URL=http://127.0.0.1:4177/api/v1
LAOGUI_CLIENT_ID=codex

# 可选：3D/CAD 集成。ForgeCAD 用于交互式参数模型编辑；text-to-cad 用于 STEP/STL/GLB 导出。
FORGECAD_BIN=forgecad
TEXT_TO_CAD_DIR=/absolute/path/to/text-to-cad
TEXT_TO_CAD_PYTHON=python3
