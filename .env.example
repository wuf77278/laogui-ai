PORT=4177
# 桌面版会自动设置到系统用户目录；普通 node 启动时留空会继续使用项目目录。
LAOGUI_DATA_DIR=
REASONING_BASE_URL=https://ai.mxou.cn
REASONING_API_KEY=sk-your-api-key
REASONING_MODEL=gpt-5.5
OPENAI_BASE_URL=https://ai.mxou.cn
OPENAI_API_KEY=sk-your-api-key
YYBB_BASE_URL=https://yybb.codes
YYBB_API_KEY=sk-your-api-key
IMAGE_BASE_URL=https://ai.mxou.cn
IMAGE_BASE_URLS=https://ai.mxou.cn
IMAGE_COST_FIRST_BASE_URLS=https://ai.mxou.cn
IMAGE_INCLUDE_DEFAULT_BASE_URLS=0
IMAGE_API_KEY=sk-your-api-key
IMAGE_API_MODE=images
IMAGE_GENERATIONS_PATH=/v1/images/generations
IMAGE_EDITS_PATH=/v1/images/edits
# Optional custom HTTP image provider manifest. Keep empty for standard OpenAI-compatible responses.
IMAGE_PROVIDER_MANIFEST=
IMAGE_RESPONSES_PATH=/v1/responses
IMAGE_MODEL=gpt-image-2
IMAGE_GEN_SKILL_MAX_ATTEMPTS=2
IMAGE_COST_FIRST_MAX_ATTEMPTS=2
IMAGE_ENDPOINT_PRECHECK_TTL_SECONDS=300
IMAGE_ALLOW_LEGACY_FALLBACK=0
IMAGE_GENERATION_CONCURRENCY=2
IMAGE_GENERATION_QUEUE_MAX_PENDING=12
IMAGE_GENERATION_QUEUE_TIMEOUT_SECONDS=600
MAX_JSON_BODY_MB=80
SAVED_MXOU_BASE_URL=https://ai.mxou.cn
SAVED_MXOU_API_KEY=sk-your-api-key
SAVED_MXOU_REASONING_MODEL=gpt-5.5
SAVED_MXOU_IMAGE_MODEL=gpt-image-2
SAVED_MXOU_RESPONSES_PATH=/v1/responses
SAVED_YYBB_BASE_URL=https://yybb.codes
SAVED_YYBB_API_KEY=sk-your-api-key
SAVED_YYBB_REASONING_MODEL=gpt-5.4
SAVED_YYBB_IMAGE_MODEL=gpt-image-2
SAVED_YYBB_RESPONSES_PATH=/responses
# 外部访问、局域网分享、内网穿透时必配。仅本机自用 localhost 时可留空。
LAOGUI_API_TOKEN=replace-with-a-private-token
API_CORS_ORIGIN=https://your-tunnel-domain.example
# Codex / CLI 桥接客户端默认读取这两个值；本机默认值也可以不填。
LAOGUI_API_BASE_URL=http://127.0.0.1:4177/api/v1
LAOGUI_CLIENT_ID=codex
